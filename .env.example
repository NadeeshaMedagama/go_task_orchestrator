# =============================================================================
# Environment Variables — Copy this file to .env and fill in real values
# =============================================================================
#   cp .env.example .env
# =============================================================================

# ──── Backend Configuration ────────────────────────────────────────────────
# Shared JWT secret for api-gateway and auth-service
# Generate with: openssl rand -base64 32
JWT_SECRET=<your-base64-encoded-jwt-secret>

# Service URLs (for local development without Docker)
AUTH_SERVICE_URL=http://localhost:8081
TASK_SERVICE_URL=http://localhost:8082

# ──── Frontend Configuration ───────────────────────────────────────────────
# API endpoint for the frontend (used during build time and in browser)
# Docker: http://api-gateway:8080/api (internal network)
# Local dev: http://localhost:8080/api
NEXT_PUBLIC_API_URL=http://localhost:8080/api

